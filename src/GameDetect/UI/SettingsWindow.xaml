<ui:FluentWindow x:Class="GameDetect.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="GameDetect Settings" 
        Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        Icon="pack://application:,,,/icon.png"
        WindowCornerPreference="Round"
        WindowBackdropType="None"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid>
        <Grid.Resources>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <ui:TitleBar Grid.Row="0" Title="GameDetect Settings" />
        
        <TabControl Grid.Row="1">
            <!-- General Settings Tab -->
            <TabItem Header="General Settings">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" MaxWidth="400" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <TextBlock Text="MQTT Broker Configuration" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ui:TextBox x:Name="TxtMqttHost" PlaceholderText="Host (e.g. 192.168.1.5)" Margin="0,5"/>
                        <ui:TextBox x:Name="TxtMqttPort" PlaceholderText="Port (e.g. 1883)" Margin="0,5"/>
                        <ui:TextBox x:Name="TxtMqttUser" PlaceholderText="Username" Margin="0,5"/>
                        <ui:PasswordBox x:Name="TxtMqttPass" PlaceholderText="Password" Margin="0,5"/>
                        
                        <TextBlock Text="Device" FontSize="18" FontWeight="SemiBold" Margin="0,20,0,10"/>
                        <ui:TextBox x:Name="TxtDeviceName" PlaceholderText="Device Name (e.g. Gaming PC)" Margin="0,5"/>
                        <ui:ToggleSwitch x:Name="ChkAutostart" Content="Run on Windows Startup" Margin="0,10,0,0"/>
                    </StackPanel>
                    
                    <ui:Button Grid.Row="1" Content="Save &amp; Apply" Click="BtnSave_Click" Margin="0,10,0,0" Appearance="Primary" HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>
            
            <!-- Custom Games Tab -->
            <TabItem Header="Custom Games">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Manually tracked game executables:" Margin="0,0,0,10"/>
                    
                    <DataGrid Grid.Row="1" x:Name="DgCustomGames" AutoGenerateColumns="False" CanUserAddRows="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Game Name" Binding="{Binding Name}" Width="1.5*"/>
                            <DataGridTextColumn Header="App ID" Binding="{Binding AppId}" Width="*"/>
                            <DataGridTextColumn Header="Launcher" Binding="{Binding Launcher}" Width="*"/>
                            <DataGridTextColumn Header="Executables (comma-separated)" Binding="{Binding ExecutablesString}" Width="2*"/>
                            <DataGridTextColumn Header="Window Title (Optional)" Binding="{Binding MatchWindowTitle}" Width="1.5*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <ui:Button Grid.Row="2" Content="Save Custom Games" Click="BtnSaveGames_Click" Margin="0,10,0,0" Appearance="Primary" HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>

            <!-- Game Mappings Tab -->
            <TabItem Header="Game Mappings">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Launcher Game Mappings (translates launcher AppIDs/Names to real game processes):" Margin="0,0,0,10"/>
                    
                    <DataGrid Grid.Row="1" x:Name="DgGameMappings" AutoGenerateColumns="False" CanUserAddRows="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Game Name" Binding="{Binding Name}" Width="1.5*"/>
                            <DataGridTextColumn Header="App ID" Binding="{Binding AppId}" Width="*"/>
                            <DataGridTextColumn Header="Launcher" Binding="{Binding Launcher}" Width="*"/>
                            <DataGridTextColumn Header="Executables (comma-separated)" Binding="{Binding ExecutablesString}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <ui:Button Grid.Row="2" Content="Save Game Mappings" Click="BtnSaveMappings_Click" Margin="0,10,0,0" Appearance="Primary" HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>
            
            <!-- Ignored List Tab -->
            <TabItem Header="Ignored List">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Left Column: Executables Blacklist -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Blacklisted executables (ignored during automatic scans):" Margin="0,0,0,10"/>
                            <DataGrid Grid.Row="1" x:Name="DgIgnoredList" AutoGenerateColumns="False" CanUserAddRows="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Executable Name (e.g. crash_handler.exe)" Binding="{Binding Executable}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                        
                        <!-- Right Column: Ignored Games -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Ignored Games (completely excluded from tracking):" Margin="0,0,0,10"/>
                            <DataGrid Grid.Row="1" x:Name="DgIgnoredGames" AutoGenerateColumns="False" CanUserAddRows="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Game Name (e.g. Wallpaper Engine)" Binding="{Binding GameName}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                    
                    <ui:Button Grid.Row="1" Content="Save Ignored Lists" Click="BtnSaveIgnored_Click" Margin="0,10,0,0" Appearance="Primary" HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>
            
            <!-- Scanned Library Tab -->
            <TabItem Header="Scanned Library">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Detected games found on this system (read-only):" Margin="0,0,0,10"/>
                    
                    <DataGrid Grid.Row="1" x:Name="DgScannedLibrary" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Resources>
                            <Style x:Key="IgnoredTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIgnored}" Value="True">
                                        <Setter Property="Opacity" Value="0.45" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Game Name" Binding="{Binding Name}" IsReadOnly="True" ElementStyle="{StaticResource IgnoredTextBlockStyle}" Width="1.5*"/>
                            <DataGridTextColumn Header="App ID" Binding="{Binding AppId}" IsReadOnly="True" ElementStyle="{StaticResource IgnoredTextBlockStyle}" Width="*"/>
                            <DataGridTextColumn Header="Launcher" Binding="{Binding Launcher}" IsReadOnly="True" ElementStyle="{StaticResource IgnoredTextBlockStyle}" Width="*"/>
                            <DataGridTextColumn Header="Primary Executable" Binding="{Binding PrimaryExecutable}" IsReadOnly="True" ElementStyle="{StaticResource IgnoredTextBlockStyle}" Width="1.5*"/>
                            <DataGridTextColumn Header="Install Path" Binding="{Binding Path}" IsReadOnly="True" ElementStyle="{StaticResource IgnoredTextBlockStyle}" Width="3*"/>
                            <DataGridTemplateColumn Header="Action" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <ui:Button Content="Ignore" Appearance="Secondary" Click="BtnIgnoreScannedGame_Click"
                                                       Visibility="{Binding IsNotIgnored, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            <ui:Button Content="Track" Appearance="Primary" Click="BtnTrackScannedGame_Click"
                                                       Visibility="{Binding IsIgnored, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <ui:Button Grid.Row="2" x:Name="BtnRestartService" Content="Restart Service" Click="BtnRestartService_Click"
                               Margin="0,10,0,0" Appearance="Primary" HorizontalAlignment="Right" Visibility="Collapsed"/>
                </Grid>
            </TabItem>

            <!-- Maintenance Tab -->
            <TabItem Header="Maintenance">
                <StackPanel Margin="20" MaxWidth="400" HorizontalAlignment="Left">
                    <TextBlock Text="Configuration Backup" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ui:Button Content="Backup Settings to Zip" Click="BtnBackup_Click" Margin="0,10,0,0" Icon="{ui:SymbolIcon ArrowDownload24}" Width="250"/>
                    <ui:Button Content="Restore Settings from Zip" Click="BtnRestore_Click" Margin="0,10,0,0" Icon="{ui:SymbolIcon ArrowUpload24}" Width="250"/>
                    
                    <TextBlock Text="Appearance" FontSize="18" FontWeight="SemiBold" Margin="0,30,0,10"/>
                    <ComboBox x:Name="CmbTheme" SelectedIndex="0" Width="200" HorizontalAlignment="Left" SelectionChanged="CmbTheme_SelectionChanged">
                        <ComboBoxItem Content="Auto (System Default)" />
                        <ComboBoxItem Content="Light Mode" />
                        <ComboBoxItem Content="Dark Mode" />
                    </ComboBox>
                    <TextBlock x:Name="TxtThemeRestartWarning" 
                               Text="* Please close and reopen settings for all theme changes to take effect." 
                               Foreground="Orange" 
                               FontSize="12" 
                               Margin="0,10,0,0" 
                               Visibility="Collapsed" />
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</ui:FluentWindow>

